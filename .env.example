# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=recon
DATABASE_URL=postgresql+psycopg://recon:change-me@db:5432/recon

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM backend ────────────────────────────────────────────
# "anthropic" -> Claude API (cloud)   "local" -> gs65, an Ollama host on the Tailnet
LLM_PROVIDER=anthropic

# Claude API — used when LLM_PROVIDER=anthropic. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6      # résumé/cover/interview features
SCORING_MODEL=claude-haiku-4-5     # bulk daily role scoring — ~3x cheaper than Sonnet

# gs65 — local LLM via Ollama over Tailscale (OpenAI-compatible /v1 API).
# Used when LLM_PROVIDER=local. No API spend; the api key value is ignored by Ollama.
LOCAL_LLM_BASE_URL=http://100.119.105.2:11434/v1
LOCAL_LLM_MODEL=gs65
LOCAL_LLM_API_KEY=ollama

# Set to "stub" to run scoring/brief without calling any LLM (dev mode)
SCORING_MODE=stub

# ─── Search sources: third-party job aggregators ────────────
# Off by default. Pulls cross-employer postings (incl. LinkedIn via JSearch's
# Google-for-Jobs index, and federal jobs via USAJobs), geo-filtered to the
# target metros, auto-creating a company per employer. Gated to once/day to
# respect provider free tiers. Free-tier math: requests/run = providers x terms
# (capped by SEARCH_MAX_QUERIES_PER_RUN); keep requests*(30/interval_days) under
# JSearch's monthly free quota — lower the cap or raise the interval if needed.
SEARCH_ENABLED=false
SEARCH_INTERVAL_HOURS=24
SEARCH_METROS_ONLY=true            # keep only results in a target metro / US-remote
SEARCH_MAX_QUERIES_PER_RUN=8       # hard cap on provider calls per run (quota guard)
SEARCH_DATE_POSTED=week            # JSearch recency: all|today|3days|week|month
# SEARCH_TERMS=technical product manager,product manager   # optional; blank -> derived from tracks
# JSearch (RapidAPI): create a free account, subscribe to JSearch, copy the key
JSEARCH_API_KEY=
# USAJobs (free): key from https://developer.usajobs.gov/apirequest/ + your contact email
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# ─── Scan behaviour ─────────────────────────────────────────
SCAN_HOUR_LOCAL=6            # daily scan kicks off at this local hour
SCAN_MIN_DELAY_SEC=2         # politeness delay between requests
SCAN_MAX_DELAY_SEC=5
SCAN_USER_AGENT=ReconJobTracker/1.0 (+mailto:you@zacharyjcollins.com)
TZ=America/Los_Angeles

# ─── App ────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# ─── Notifications: web push ─────────────────────────────────
# Disabled by default. To enable, generate a VAPID keypair with either:
#   python -m py_vapid --gen   (pip install py-vapid)
#   or: vapid --gen
# This writes private_key.pem / public_key.pem (or prints base64url values
# depending on the tool version) — paste the base64url public/private keys below.
NOTIFY_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:zakslax@gmail.com

# ─── Notifications: email ────────────────────────────────────
# Disabled by default. Configure an SMTP relay (e.g. Gmail app password,
# SendGrid, Mailgun) to send the daily brief via email.
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ─── Notifications: Google Doc ───────────────────────────────
# Disabled by default. Requires a Google Cloud service-account JSON key
# (Docs API + Drive API enabled) and a Drive folder ID shared with that
# service account. Mount/copy the key file into the container and point
# GDOC_CREDENTIALS_JSON at its path.
NOTIFY_GDOC_ENABLED=false
GDOC_CREDENTIALS_JSON=
GDOC_FOLDER_ID=
