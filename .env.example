# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=recon
DATABASE_URL=postgresql+psycopg://recon:change-me@db:5432/recon

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Claude API ─────────────────────────────────────────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
# Set to "stub" to run scoring/brief without spending tokens (dev mode)
SCORING_MODE=stub

# ─── Scan behaviour ─────────────────────────────────────────
SCAN_HOUR_LOCAL=6            # daily scan kicks off at this local hour
SCAN_MIN_DELAY_SEC=2         # politeness delay between requests
SCAN_MAX_DELAY_SEC=5
SCAN_USER_AGENT=ReconJobTracker/1.0 (+mailto:you@zacharyjcollins.com)
TZ=America/Los_Angeles

# ─── App ────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
